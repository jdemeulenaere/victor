maven = use_extension("@rules_jvm_external//:extensions.bzl", "maven")
maven.from_toml(
    name = "third_party",
    libs_versions_toml = "//third_party/maven:libs.versions.toml",
)

maven.install(
    name = "third_party",
    aar_import_bzl_label = "@rules_android//rules:rules.bzl",
    lock_file = "//third_party/maven:maven_install.json",
    version_conflict_policy = "pinned",
    repositories = [
        "https://maven.google.com",
        "https://repo1.maven.org/maven2",
    ],
    use_starlark_android_rules = True,
)

# Keep a separate shared @maven repo for transitive modules (grpc-java/protobuf).
# This avoids mixing first-party TOML dependencies into their graph.
MAVEN_FORCE_ARTIFACTS = [
    ("com.google.code.findbugs", "jsr305", "3.0.2"),
    ("com.google.code.gson", "gson", "2.12.1"),
    ("com.google.errorprone", "error_prone_annotations", "2.44.0"),
    ("com.google.guava", "guava", "32.0.1-jre"),
]

_ = [maven.artifact(
        name = "maven",
        group = group,
        artifact = artifact,
        version = version,
        force_version = True,
    ) for (group, artifact, version) in MAVEN_FORCE_ARTIFACTS]

maven.install(
    name = "maven",
    known_contributing_modules = ["grpc-java", "protobuf", "victor"],
)
use_repo(maven, "third_party")
