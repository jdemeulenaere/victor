maven = use_extension("@rules_jvm_external//:extensions.bzl", "maven")

kmp_maven_variants_repository = use_repo_rule(
    "//build/rules/kotlin/multiplatform:kmp_maven_variants_repository.bzl",
    "kmp_maven_variants_repository",
)

kmp_maven_variants_repository(
    name = "third_party_maven_kmp_variants",
    maven_install_json = "//third_party/maven:maven_install.json",
    maven_repo = "third_party_maven",
)

http_file = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_file")

http_file(
    name = "kotlinx_rpc_protoc_gen_grpc_kotlin_multiplatform_all",
    downloaded_file_path = "protoc-gen-grpc-kotlin-multiplatform-0.11.0-grpc-188-all.jar",
    sha256 = "0799b31943dce5159d4a874814e5dc2f9f61d77de4550952d3b6cda0c6830045",
    urls = ["https://redirector.kotlinlang.org/maven/kxrpc-grpc/org/jetbrains/kotlinx/protoc-gen-grpc-kotlin-multiplatform/0.11.0-grpc-188/protoc-gen-grpc-kotlin-multiplatform-0.11.0-grpc-188-all.jar"],
)

http_file(
    name = "kotlinx_rpc_protoc_gen_kotlin_multiplatform_all",
    downloaded_file_path = "protoc-gen-kotlin-multiplatform-0.11.0-grpc-188-all.jar",
    sha256 = "61ff8fa923515a80879334ad8b52313ff87b4f637279c01e79ff7dcabd78a5fa",
    urls = ["https://redirector.kotlinlang.org/maven/kxrpc-grpc/org/jetbrains/kotlinx/protoc-gen-kotlin-multiplatform/0.11.0-grpc-188/protoc-gen-kotlin-multiplatform-0.11.0-grpc-188-all.jar"],
)

maven.from_toml(
    name = "third_party",
    libs_versions_toml = "//third_party/maven:libs.versions.toml",
)

THIRD_PARTY_FORCE_ARTIFACTS = [
    # keep-sorted start
    ("com.google.protobuf", "protobuf-java", "4.34.1"),
    ("com.google.protobuf", "protobuf-java-util", "4.34.1"),
    # keep-sorted end
]

_third_party_force = [maven.artifact(
    name = "third_party",
    artifact = artifact,
    force_version = True,
    group = group,
    version = version,
) for (group, artifact, version) in THIRD_PARTY_FORCE_ARTIFACTS]

maven.install(
    name = "third_party",
    aar_import_bzl_label = "@rules_android//rules:rules.bzl",
    lock_file = "//third_party/maven:maven_install.json",
    repositories = [
        "https://repo.maven.apache.org/maven2",
        "https://maven.google.com",
        "https://redirector.kotlinlang.org/maven/kxrpc-grpc",
    ],
    use_starlark_android_rules = True,
    version_conflict_policy = "pinned",
)
maven.override(
    name = "third_party",
    coordinates = "com.google.guava:listenablefuture",
    target = "//third_party/maven/overrides/guava:listenablefuture_from_guava",
)

# Keep a separate shared @maven repo for transitive modules (grpc-java/protobuf).
# This avoids mixing first-party TOML dependencies into their graph.
MAVEN_FORCE_ARTIFACTS = [
    # keep-sorted start
    ("com.google.code.findbugs", "jsr305", "3.0.2"),
    ("com.google.code.gson", "gson", "2.14.0"),
    ("com.google.errorprone", "error_prone_annotations", "2.49.0"),
    ("com.google.guava", "guava", "33.6.0-jre"),
    # keep-sorted end
]

_ = [maven.artifact(
    name = "maven",
    artifact = artifact,
    force_version = True,
    group = group,
    version = version,
) for (group, artifact, version) in MAVEN_FORCE_ARTIFACTS]

maven.install(
    name = "maven",
    known_contributing_modules = [
        # keep-sorted start
        "grpc-java",
        "protobuf",
        "victor",
        # keep-sorted end
    ],
    repositories = [
        "https://repo.maven.apache.org/maven2",
        "https://maven.google.com",
    ],
)
use_repo(maven, third_party_maven = "third_party")
