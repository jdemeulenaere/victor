+
+alias(
+    name = "protoc_prebuilt_for_host",
+    actual = select({
+        ":protoc_host_linux_aarch64": ":protoc_prebuilt_linux_aarch64_tool",
+        ":protoc_host_linux_ppc64le": ":protoc_prebuilt_linux_ppc64le_tool",
