+    visibility = ["//visibility:private"],
+)
+
+alias(
+    name = "protoc",
+    actual = select({
+        "//bazel/toolchains:prefer_prebuilt_protoc.flag_set": ":protoc_prebuilt_for_host",
+        "//conditions:default": ":protoc_compiled",
+    }),
+    visibility = ["//visibility:public"],
+)
+
 cc_binary(
     name = "protoc_stage0",
     copts = COPTS,
