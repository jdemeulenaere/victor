common --enable_bzlmod
common --incompatible_autoload_externally=cc_binary,cc_import,cc_library,cc_test,java_binary,java_library,java_proto_library,proto_library,py_binary,py_library
# Required so proto language toolchains are selected via toolchain resolution.
common --incompatible_enable_proto_toolchain_resolution
# Use protobuf's prebuilt protoc (v33.4+) to avoid rebuilding C++ protobuf tools on clean builds.
common --@com_google_protobuf//bazel/toolchains:prefer_prebuilt_protoc

common --java_runtime_version=remotejdk_21
common --tool_java_runtime_version=remotejdk_21
common --java_language_version=21
common --tool_java_language_version=21

# Always package Android binaries for arm64-v8a, independent of the host CPU.
build --android_platforms=@rules_android//:arm64-v8a

# Keep Android desugar within the memory budget of small cloud runners.
build --worker_max_instances=Desugar=1

# CI logs are non-interactive, so reduce progress chatter without changing
# normal build/test behavior or failure reporting.
common:ci --curses=no
common:ci --noshow_loading_progress
common:ci --show_progress_rate_limit=30
common:ci --progress_report_interval=60
common:ci --ui_actions_shown=1
