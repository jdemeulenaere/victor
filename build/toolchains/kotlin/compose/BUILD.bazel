load("@rules_java//java:defs.bzl", "java_import")
load("//build/rules/kotlin/multiplatform:compiler_plugin.bzl", "kt_compiler_plugin")

java_import(
    name = "compose_compiler_plugin_embeddable",
    jars = ["@kotlin_compose_compiler_plugin_embeddable_2_3_20//file"],
)

kt_compiler_plugin(
    name = "compose_compiler_plugin",
    id = "androidx.compose.compiler.plugins.kotlin",
    native_deps = [":compose_compiler_plugin_embeddable"],
    visibility = ["//visibility:public"],
    deps = ["@third_party_maven//:org_jetbrains_kotlin_kotlin_compose_compiler_plugin"],
)

alias(
    name = "skiko_runtime",
    actual = select({
        "@bazel_tools//src/conditions:darwin_arm64": "@third_party_maven//:org_jetbrains_skiko_skiko_awt_runtime_macos_arm64",
        "@bazel_tools//src/conditions:darwin_x86_64": "@third_party_maven//:org_jetbrains_skiko_skiko_awt_runtime_macos_x64",
        "@bazel_tools//src/conditions:linux_aarch64": "@third_party_maven//:org_jetbrains_skiko_skiko_awt_runtime_linux_arm64",
        "@bazel_tools//src/conditions:linux_x86_64": "@third_party_maven//:org_jetbrains_skiko_skiko_awt_runtime_linux_x64",
        "@bazel_tools//src/conditions:windows_arm64": "@third_party_maven//:org_jetbrains_skiko_skiko_awt_runtime_windows_arm64",
        "@bazel_tools//src/conditions:windows_x64": "@third_party_maven//:org_jetbrains_skiko_skiko_awt_runtime_windows_x64",
        "//conditions:default": "@third_party_maven//:org_jetbrains_skiko_skiko_awt_runtime_macos_arm64",
    }),
    visibility = ["//visibility:public"],
)
