load(
    "//build/rules:defs.bzl",
    "kmp_source_sets",
    "kmp_targets",
    "kt_android_library",
    "kt_multiplatform_library",
)

kt_multiplatform_library(
    name = "jvm_only_library",
    source_sets = kmp_source_sets(srcs = {
        "common": ["JvmOnlyApi.kt"],
    }),
    targets = kmp_targets(["jvm"]),
)

kt_android_library(
    name = "android_consumes_jvm_only_library",
    srcs = ["AndroidConsumesJvmOnly.kt"],
    custom_package = "victor.rules.kotlin.multiplatform.testdata",
    deps = [":jvm_only_library"],
)

kt_multiplatform_library(
    name = "android_and_jvm_library",
    source_sets = kmp_source_sets(srcs = {
        "android": ["AndroidOnlyApi.kt"],
        "common": ["CommonApi.kt"],
    }),
    targets = kmp_targets(
        [
            "android",
            "jvm",
        ],
        android_namespace = "victor.rules.kotlin.multiplatform.testdata",
    ),
)

kt_android_library(
    name = "android_prefers_android_library_variant",
    srcs = ["AndroidConsumesAndroidVariant.kt"],
    custom_package = "victor.rules.kotlin.multiplatform.testdata",
    deps = [":android_and_jvm_library"],
)
