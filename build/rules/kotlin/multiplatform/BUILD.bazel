load("@rules_shell//shell:sh_test.bzl", "sh_test")
load(":compiler_plugin_test.bzl", "kt_native_compiler_plugin_test")

exports_files([
    "compiler_plugin.bzl",
    "compiler_plugin_test.bzl",
    "defs.bzl",
    "ios.bzl",
    "kmp_maven_variants_repository.bzl",
    "toolchains.bzl",
    "wasm.bzl",
    "wasm_kotlinc.sh",
])

genquery(
    name = "kmp_maven_android_compose_variant_deps",
    expression = "deps(set(@third_party_maven_kmp_variants//:org_jetbrains_compose_foundation_foundation_android_metadata_variant @third_party_maven_kmp_variants//:org_jetbrains_compose_material3_material3_android_metadata_variant @third_party_maven_kmp_variants//:org_jetbrains_compose_ui_ui_android_metadata_variant))",
    opts = ["--output=label"],
    scope = [
        "@third_party_maven_kmp_variants//:org_jetbrains_compose_foundation_foundation_android_metadata_variant",
        "@third_party_maven_kmp_variants//:org_jetbrains_compose_material3_material3_android_metadata_variant",
        "@third_party_maven_kmp_variants//:org_jetbrains_compose_ui_ui_android_metadata_variant",
    ],
)

sh_test(
    name = "kmp_maven_variants_test",
    srcs = ["kmp_maven_variants_test.sh"],
    args = [
        "$(location @third_party_maven_kmp_variants//:variants.bzl)",
        "$(location :kmp_maven_android_compose_variant_deps)",
    ],
    data = [
        ":kmp_maven_android_compose_variant_deps",
        "@third_party_maven_kmp_variants//:variants.bzl",
    ],
)

toolchain_type(
    name = "native_toolchain_type",
    visibility = ["//visibility:public"],
)

toolchain_type(
    name = "wasm_toolchain_type",
    visibility = ["//visibility:public"],
)

kt_native_compiler_plugin_test(
    name = "compose_compiler_plugin_native_deps_test",
    plugin = "//build/toolchains/kotlin/compose:compose_compiler_plugin",
)

kt_native_compiler_plugin_test(
    name = "serialization_compiler_plugin_native_deps_test",
    plugin = "//build/toolchains/kotlin/serialization:serialization_compiler_plugin",
)

kt_native_compiler_plugin_test(
    name = "rpc_compiler_plugin_native_deps_test",
    plugin = "//build/toolchains/kotlin/rpc:rpc_compiler_plugin",
)
