{
  "name": "victor-monorepo",
  "private": true,
  "packageManager": "pnpm@8.15.9",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "./build.sh",
    "build:backend": "bazel build //backend",
    "build:web": "bazel build //web:build",
    "build:scripts": "bazel build //scripts",
    "run:backend": "bazel run //backend",
    "run:web:dev": "bazel run //web:dev",
    "run:scripts": "bazel run //scripts"
  },
  "workspaces": [
    "web"
  ],
  "pnpm": {
    "overrides": {
      "@types/react": "^18.2.66",
      "@types/react-dom": "^18.2.22",
      "@vitejs/plugin-react": "^4.2.1",
      "react": "^18.2.0",
      "react-dom": "^18.2.0",
      "typescript": "^5.2.2",
      "vite": "^5.2.0"
    }
  }
}
